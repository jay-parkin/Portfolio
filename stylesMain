:root {
  /* CSS HEX */
  --cherry-blossom-pink: #edafb8ff;
  --champagne-pink: #f7e1d7ff;
  --timberwolf: #dedbd2ff;
  --ash-gray: #b0c4b1ff;
  --outer-space: #4a5759ff;

  font-family: sans-serif;
}

* {
  margin: 0;
}

body {
  display: flex;
  flex-direction: column;
  background-color: white;
  justify-content: center;
  align-items: center;
  overflow-x: hidden;
}

header {
  background-color: var(--timberwolf);
  height: 10vh;
  width: 100%;

  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;

  border-bottom: 1px solid var(--outer-space);
}

.nav-bar {
  display: flex;
  justify-content: flex-end;
}

nav {
  margin: 0.5em;
}

nav > a {
  margin-right: 1em;
  text-decoration: none;
  background-color: var(--outer-space);
  color: var(--timberwolf);
  padding: 0.25em;
  border-radius: 0.5em;
}

nav > a:hover {
  background-color: var(--outer-space);
}

.portfolio-logo > img {
  margin-left: 1em;
  height: 5vh;
  object-fit: cover;
}

main {
  min-height: 85dvh;
  width: 100%;
  text-align: center;

  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

main > * {
  margin: 1em;
}

#developer-home-image img {
  height: 30dvh;
  object-fit: cover;
}

footer {
  background-color: var(--timberwolf);
  height: 5dvh;
  width: 100%;
  text-align: center;

  display: flex;
  justify-content: center;
  align-items: center;
}

/* resourced from https://alvarotrigo.com/blog/hamburger-menu-css/ */
label .menu {
  position: absolute; /* Adjusted position */
  right: 0;
  top: 0;
  z-index: 100;
  width: 100px;
  height: 10vh;
  /* background: #fff; */
  border-radius: 50% 0% 0% 50%;
  -webkit-transition: width 0.5s ease-in-out, height 0.5s ease-in-out; /* Transition width and height */
  transition: width 0.5s ease-in-out, height 0.5s ease-in-out;
  box-shadow: 0 0 0 0 #fff, 0 0 0 0 #fff;
  cursor: pointer;
}

/* Middle bar of the menu */
label .hamburger {
  position: absolute;
  top: 45px;
  left: 40px;
  width: 30px;
  height: 2px;
  background: var(--outer-space);
  display: block;
  -webkit-transform-origin: center;
  transform-origin: center;
  -webkit-transition: 0.5s ease-in-out;
  transition: 0.5s ease-in-out;
  background: #fff;
}

/*  Top and bottom bars of the menu */
label .hamburger:after,
label .hamburger:before {
  -webkit-transition: 0.5s ease-in-out;
  transition: 0.5s ease-in-out;
  content: "";
  position: absolute;
  display: flex;
  width: 100%;
  height: 100%;
  background: var(--outer-space);
  background: #fff;
}

label .hamburger:before {
  top: -10px;
}

label .hamburger:after {
  bottom: -10px;
}

label input {
  display: none;
}

label input:checked + .menu {
  width: 50vw; /* Expand width to full viewport width */
  height: 50vh; /* Expand height to full viewport height */
  border-radius: 0; /* Remove circular border-radius */
  background: #fff;
}

label input:checked + .menu .hamburger {
  -webkit-transform: rotate(45deg);
  transform: rotate(45deg);
  background: #000000;
}

label input:checked + .menu .hamburger:after {
  -webkit-transform: rotate(90deg);
  transform: rotate(90deg);
  bottom: 0;
  background: #000000;
}

label input:checked + .menu .hamburger:before {
  -webkit-transform: rotate(90deg);
  transform: rotate(90deg);
  top: 0;
  background: #000000;
}

label input:checked + .menu + ul {
  opacity: 1;
}

label ul {
  z-index: 200;
  position: absolute;
  top: 30%;
  left: 70%;
  -webkit-transform: translate(-50%, -50%);
  transform: translate(-50%, -50%);
  opacity: 0;
  -webkit-transition: 0.25s 0s ease-in-out;
  transition: 0.25s 0s ease-in-out;
}

label a {
  font-size: 1.5rem;
  margin-bottom: 1em;
  display: block;
  color: var(--outer-space);
  text-decoration: none;
}

/* Media query for even smaller viewports */
@media screen and (min-width: 600px) {
  label .menu {
    display: none;
  }
}

@media screen and (max-width: 600px) {
  .nav-bar {
    display: none;
  }
}
